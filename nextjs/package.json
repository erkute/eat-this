    "@sentry/nextjs": "^10.52.0",
    "dotenv": "^17.4.2",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "maplibre-gl": "^5.24.0",
    "next": "15.5.15",
