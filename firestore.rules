rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rate-limit buckets — admin SDK only, never from clients
    match /_rateLimits/{doc} {
      allow read, write: if false;
    }

    // Favorites — each user may only read/write their own document
    // Document structure: /favorites/{uid}/spots/{spotId}
    match /favorites/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
