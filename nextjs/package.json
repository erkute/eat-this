{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:css && next dev",
    "build:css": "esbuild css/style.css --bundle=false --minify --outfile=public/css/style.min.css",
    "build": "npm run build:css && next build && cp -r public/. .next/standalone/public/",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sanity/client": "^7.21.0",
    "@sanity/image-url": "^2.1.1",
    "firebase": "^12.12.1",
    "next": "15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "jsdom": "^29.0.2",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
