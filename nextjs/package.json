{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19 <21"
  },
  "scripts": {
    "dev": "npm run build:css && next dev",
    "build:css": "esbuild css/style.css --bundle=false --minify --outfile=public/css/style.min.css",
    "build": "npm run build:css && next build && cp -r public/. .next/standalone/public/",
    "build:isolated": "npm run build:css && NEXT_DIST_DIR=.next-verify next build && cp -r public/. .next-verify/standalone/public/",
    "start": "next start",
    "import:restaurant": "tsx scripts/import-enriched.ts",
    "embed:restaurants": "tsx scripts/embed-restaurants.ts",
    "content:backlog": "tsx scripts/content-backlog.ts",
    "premium:migrate": "tsx scripts/migrate-must-eats-private.ts",
    "lint": "eslint",
    "lint:content": "tsx scripts/content-lint.ts",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore,storage --project eat-this-rules-test \"vitest run __tests__/firestore.rules.test.ts __tests__/storage.rules.test.ts\"",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.94.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sanity/client": "^7.22.1",
    "@sentry/nextjs": "^10.57.0",
    "dotenv": "^17.4.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.40.0",
    "maplibre-gl": "^5.24.0",
    "next": "15.5.19",
    "next-intl": "^4.13.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-map-gl": "^8.1.1",
    "resend": "^6.12.4",
    "server-only": "0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0"
  },
  "optionalDependencies": {
    "@parcel/watcher-linux-x64-glibc": "2.5.6",
    "@rolldown/binding-darwin-arm64": "^1.1.4",
    "@rolldown/binding-linux-x64-gnu": "^1.0.0-rc.16",
    "@swc/core-linux-x64-gnu": "1.15.30"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.42",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.16",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.15"
    },
    "uuid": "^11.1.1"
  }
}
