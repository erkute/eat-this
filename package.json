{
  "name": "eat-this",
  "version": "1.0.0",
  "keywords": [
    "food-blog",
    "berlin",
    "seo"
  ],
  "author": "EAT THIS",
  "license": "ISC",
  "description": "EAT THIS - Berlin Food Blog",
  "type": "module",
  "scripts": {
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "format": "prettier --write \"js/**/*.js\" \"functions/index.js\" \"functions/templates.js\"",
    "format:check": "prettier --check \"js/**/*.js\"",
    "test": "playwright test --passWithNoTests",
    "test:ui": "playwright test --ui",
    "build:articles": "node scripts/generate-articles.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "serve": "^14.2.6"
  }
}
