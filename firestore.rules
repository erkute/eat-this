rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /_rateLimits/{doc} {
      allow read, write: if false;
    }

    // Legacy path — kept for backwards compatibility
    match /favorites/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // User profile doc — owner-readable; writes restricted to the avatar
    // field so the client can't bloat the doc with arbitrary fields.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['avatar', 'onboardedAt'])
        && (!('avatar' in request.resource.data)
            || request.resource.data.avatar == null
            || request.resource.data.avatar in [1, 2, 3])
        && (!('onboardedAt' in request.resource.data)
            || request.resource.data.onboardedAt is timestamp);
    }

    // Current paths used by the React app
    match /users/{uid}/favorites/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/unlockedMustEats/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // User pack unlocks — read by owner only; writes are admin-SDK only
    match /userPacks/{uid}/{document=**} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Booster packs (Feature C) — owner-readable; client may create with a
    // validated shape and update only to flip opened: false → true. Cards
    // and createdAt are immutable after create.
    match /users/{uid}/packs/{packId} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.opened == false
        && request.resource.data.openedAt == null
        && request.resource.data.mustEatIds is list
        && request.resource.data.mustEatIds.size() > 0
        && request.resource.data.mustEatIds.size() <= 20
        && request.resource.data.createdAt == request.time;

      allow update: if request.auth != null
        && request.auth.uid == uid
        && resource.data.opened == false
        && request.resource.data.opened == true
        && request.resource.data.mustEatIds == resource.data.mustEatIds
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.openedAt == request.time;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
