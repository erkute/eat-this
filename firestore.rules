rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /_rateLimits/{doc} {
      allow read, write: if false;
    }

    // User profile doc — owner-readable; writes restricted to the avatar
    // field so the client can't bloat the doc with arbitrary fields.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['avatar', 'onboardedAt'])
        && (!('avatar' in request.resource.data)
            || request.resource.data.avatar == null
            || request.resource.data.avatar in [1, 2, 3])
        && (!('onboardedAt' in request.resource.data)
            || request.resource.data.onboardedAt is timestamp);
    }

    // Favorites are created/deleted only by /api/heart via the Admin SDK so
    // the per-user document and public aggregate always move together. The
    // owner may edit only the optional profile note; all canonical restaurant
    // metadata remains server-owned.
    match /users/{uid}/favorites/{restaurantId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, delete: if false;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['note'])
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 180;
    }

    // On-site must-eat reveals — owner-readable so the client can seed its
    // unlocked set on load. Writes are server-only via the Admin SDK
    // (/api/must-eat-reveal), which also enforces the per-uid reveal
    // rate-limit; client-side writes would route around that limit, so they
    // are denied here (the client only ever reads this collection).
    match /users/{uid}/unlockedMustEats/{document=**} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Referral bonuses (Plan 4) — owner-readable so the client can subscribe
    // with onSnapshot (ReferralToastListener + MapSection). Writes are
    // server-only via the Admin SDK (/api/referral/confirm).
    match /users/{uid}/referralBonuses/{document=**} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Shared inviter counters serialize concurrent referral awards. They are
    // internal bookkeeping and never exposed to the client.
    match /users/{uid}/referralStats/{document=**} {
      allow read, write: if false;
    }

    // Entitlements (Sub-Project 1 of monetisation) — owner-readable so the
    // client can subscribe with onSnapshot to react when a Stripe webhook
    // lands a new entitlement doc. Writes are server-only via Admin SDK
    // (Cloud Functions / future Stripe webhook handler).
    match /users/{uid}/entitlements/{packId} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Public heart counts (loved-by-N). The per-user heart docs live under
    // users/{uid}/favorites; this is the denormalised aggregate, maintained
    // server-side by the /api/heart Admin SDK transaction (same transaction
    // that writes the favorite). Anyone may read it (incl. anon visitors); the
    // client never writes it.
    match /restaurants/{restaurantId} {
      allow read:  if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
